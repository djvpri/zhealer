# Database (Railway PostgreSQL baru khusus zhealer)
DATABASE_URL=postgresql://user:password@host:5432/zomet_healer

# Railway API (token saja, project ID tidak perlu — auto-fetch semua project)
RAILWAY_TOKEN=your_railway_token

# LLM — pilih salah satu:
# Opsi 1: 9router
LLM_BASE_URL=https://9router.your-domain.com
LLM_API_KEY=your_9router_key
LLM_MODEL=OJAMET

# Opsi 2: Anthropic langsung
# LLM_BASE_URL=https://api.anthropic.com
# LLM_API_KEY=sk-ant-xxxxx
# LLM_MODEL=claude-sonnet-4-6

# GitHub
GITHUB_TOKEN=ghp_xxxxx

# Settings
CRON_INTERVAL=*/30 * * * *
PORT=3000
