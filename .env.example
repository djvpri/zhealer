# Database (Railway PostgreSQL baru khusus healer)
DATABASE_URL=postgresql://user:password@host:5432/zomet_healer

# Railway API
# PROJECT_ID tidak perlu — healer auto-fetch semua project dari akun kamu
RAILWAY_TOKEN=your_railway_token

# LLM - pilih salah satu:
# Opsi 1: Anthropic langsung
LLM_BASE_URL=https://api.anthropic.com
LLM_API_KEY=sk-ant-xxxxx
LLM_MODEL=claude-sonnet-4-6

# Opsi 2: 9router (ganti URL sesuai deployment 9router kamu)
# LLM_BASE_URL=https://9router.your-domain.com
# LLM_API_KEY=your_9router_key
# LLM_MODEL=OJAMET

# GitHub
GITHUB_TOKEN=ghp_xxxxx

# WhatsApp notification via clawdbot
CLAWDBOT_WEBHOOK_URL=https://clawdbot-url/api/send-message
WA_NOTIFY_NUMBER=6281234567890

# Settings
CRON_INTERVAL=*/30 * * * *
PORT=3000
